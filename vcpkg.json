{
  "name": "simple-game-framework",
  "version-string": "0.0.1",
  "builtin-baseline": "5e61fbe0fe032db1c1342a206c4a11d8ce3723bf",
  "dependencies": [
    "glew",
    "glm",
    "sdl2",
    {
      "name": "sdl2-image",
      "features": [ "libjpeg-turbo" ]
    },
    {
      "name": "sdl2-mixer",
      "features": [
        "mpg123",
        "wavpack"
      ]
    },
    "sdl2-ttf",
    {
      "name": "imgui",
      "features": [
        "opengl3-binding",
        "sdl2-binding",
        "docking-experimental"
      ]
    },
    "pugixml",
    "nlohmann-json",
    "nativefiledialog-extended"
  ],
  "overrides": [
    { "name": "imgui", "version": "1.90.6" }
  ]
}